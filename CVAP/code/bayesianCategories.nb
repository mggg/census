  RowBox[{"mu0", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"100", ",", 
     RowBox[{"Length", "@", "x"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sigma0", "=", 
   RowBox[{"100", "*", 
    RowBox[{"IdentityMatrix", "@", 
     RowBox[{"Length", "@", "x"}]}]}]}], ";"}], "\[IndentingNewLine]", 
