      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", 
         RowBox[{"ySigma", "^", "2"}]}], ")"}], " ", 
       RowBox[{
        RowBox[{"Transpose", "[", "a", "]"}], ".", "y"}]}]}], ")"}]}]}], 
  ";"}]}], "Input",
