Cell[BoxData[{
 RowBox[{
  RowBox[{"sigma", "=", 
   RowBox[{"Inverse", "[", 
    RowBox[{
     RowBox[{"Inverse", "[", "sigma0", "]"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"ySigma", "^", "2"}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"Transpose", "[", "a", "]"}], ".", "a"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mu", "=", 
   RowBox[{"sigma", ".", 
    RowBox[{"(", 
