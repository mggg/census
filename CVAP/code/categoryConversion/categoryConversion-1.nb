          RowBox[{"{", "\"\<BlackOrAfricanAmerican\>\"", "}"}], ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<BlackOrAfricanAmerican\>\"", 
            ",", "\"\<HispanicOrLatino\>\""}], "}"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<AsianAlone\>\"", "->", 
