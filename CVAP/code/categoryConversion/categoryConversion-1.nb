    RowBox[{
     RowBox[{"Authentication", ":>", 
      RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"\"\<APIBase\>\"", "->", "\"\<api.census.gov\>\""}]}], 
