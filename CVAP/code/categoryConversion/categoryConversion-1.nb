Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}], 
   "=", "\"\<your Census API key\>\""}], "*)"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"f4de0328-e141-423c-ab1a-4eda56efe578"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "censusQuery", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Authentication", ":>", 
      RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"\"\<APIBase\>\"", "->", "\"\<api.census.gov\>\""}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.922479911547374*^9, 3.922479929606248*^9}, {
   3.9224800492421618`*^9, 3.922480062096148*^9}, 3.92248026029036*^9, {
   3.922538194005389*^9, 3.922538202913189*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"c077cd48-afb0-4fca-8996-b2af92d958de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"censusQuery", "[", 
   RowBox[{"path_", ",", "query_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Enclose", "@", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rawResponse", ",", "responseList"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rawResponse", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"URLRead", "@", 
         RowBox[{"HTTPRequest", "[", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<Scheme\>\"", "->", "\"\<HTTPS\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Domain\>\"", "->", 
             RowBox[{"OptionValue", "[", "\"\<APIBase\>\"", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Path\>\"", "->", "path"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Query\>\"", "->", 
             RowBox[{"Join", "[", "\[IndentingNewLine]", 
              RowBox[{"query", ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"\"\<key\>\"", "->", 
                 RowBox[{"OptionValue", "[", "Authentication", "]"}]}], 
                "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
           "\[IndentingNewLine]", "|>"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"responseList", "=", 
       RowBox[{"Confirm", "[", 
        RowBox[{
         RowBox[{"Import", "[", 
          RowBox[{"rawResponse", ",", "\"\<RawJSON\>\""}], "]"}], ",", 
         "rawResponse"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ToTabular", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "responseList"}], ",", "\"\<Rows\>\"", ",", 
        RowBox[{"<|", 
         RowBox[{"\"\<ColumnKeys\>\"", "->", 
          RowBox[{"First", "@", "responseList"}]}], "|>"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"364d4f2d-a39d-432b-bf35-c8a04c111e59"]
}, Open  ]]
}, Open  ]],

