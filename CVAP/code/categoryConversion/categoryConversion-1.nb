Cell[BoxData[
 RowBox[{
  RowBox[{"censusQuery", "[", 
   RowBox[{"path_", ",", "query_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Enclose", "@", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rawResponse", ",", "responseList"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rawResponse", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"URLRead", "@", 
         RowBox[{"HTTPRequest", "[", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<Scheme\>\"", "->", "\"\<HTTPS\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Domain\>\"", "->", 
             RowBox[{"OptionValue", "[", "\"\<APIBase\>\"", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Path\>\"", "->", "path"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Query\>\"", "->", 
             RowBox[{"Join", "[", "\[IndentingNewLine]", 
              RowBox[{"query", ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"\"\<key\>\"", "->", 
                 RowBox[{"OptionValue", "[", "Authentication", "]"}]}], 
                "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
           "\[IndentingNewLine]", "|>"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"responseList", "=", 
       RowBox[{"Confirm", "[", 
        RowBox[{
         RowBox[{"Import", "[", 
          RowBox[{"rawResponse", ",", "\"\<RawJSON\>\""}], "]"}], ",", 
         "rawResponse"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ToTabular", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "responseList"}], ",", "\"\<Rows\>\"", ",", 
        RowBox[{"<|", 
         RowBox[{"\"\<ColumnKeys\>\"", "->", 
          RowBox[{"First", "@", "responseList"}]}], "|>"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"364d4f2d-a39d-432b-bf35-c8a04c111e59"]
