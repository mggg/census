Cell[BoxData[
 RowBox[{
  RowBox[{"acsCategoriesIndices", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{"raceEthnicityAxesIndices", "@*", "Sort"}], ",", 
     RowBox[{"<|", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<WhiteAlone\>\"", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "\"\<White\>\"", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<White\>\"", ",", "\"\<HispanicOrLatino\>\""}], 
           "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"\"\<BlackOrAfricanAmericanAlone\>\"", "->", 
        RowBox[{"{", 
