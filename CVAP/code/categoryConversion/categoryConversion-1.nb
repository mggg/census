Cell[BoxData[
 RowBox[{
  RowBox[{"getVAPStatePUMS", "[", "fipsCode_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Select", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ConstructColumns", "[", 
     RowBox[{
      RowBox[{"getVAPStatePUMSRaw", "[", "fipsCode", "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<PersonWeight\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"Cast", "[", 
           RowBox[{"#PWGTP", ",", "\"\<UnsignedInteger16\>\""}], "]"}], 
          "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Age\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"Cast", "[", 
           RowBox[{"#AGEP", ",", "\"\<UnsignedInteger8\>\""}], "]"}], "]"}]}],
         ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Citizen\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#CIT", "=!=", "\"\<5\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<HispanicOrLatino\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#HISP", "=!=", "\"\<01\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<White\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#RACWHT", "===", "\"\<1\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<BlackOrAfricanAmerican\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#RACBLK", "===", "\"\<1\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Asian\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#RACASN", "===", "\"\<1\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<AmericanIndianAndAlaskaNative\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#RACAIAN", "===", "\"\<1\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<NativeHawaiianAndOtherPacificIslander\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"#RACNH", "===", "\"\<1\>\""}], "||", 
           RowBox[{"#RACPI", "===", "\"\<1\>\""}]}], "]"}]}], ",", 
        RowBox[{"(*", 
         RowBox[{
         "PUMS", " ", "splits", " ", "only", " ", "this", " ", "category", " ",
           "into", " ", "two", " ", "variables", " ", "for", " ", "some", " ",
           "reason"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\"\<SomeOtherRace\>\"", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"#RACSOR", "===", "\"\<1\>\""}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"#Age", ">=", "18"}], "&"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"b29caf10-feef-49e2-b9c0-c6b8b17de99f"]
}, Open  ]]
}, Open  ]],

