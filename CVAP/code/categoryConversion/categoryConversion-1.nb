          RowBox[{"{", 
           RowBox[{"\"\<Asian\>\"", ",", "\"\<HispanicOrLatino\>\""}], 
           "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"\"\<AmericanIndianAndAlaskaNativeAlone\>\"", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "\"\<AmericanIndianAndAlaskaNative\>\"", "}"}], ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<AmericanIndianAndAlaskaNative\>\"", 
