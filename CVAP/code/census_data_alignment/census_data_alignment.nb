        RowBox[{"{", 
         RowBox[{"0", ",", "1300"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1300"}], "}"}]}], "}"}]}], ","}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<ACS N(B01001A_001E) - N(B01001H_001E)\>\"", 
      ",", "\"\<Decennial N(P1_003N) - N(P2_005N)\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", 
