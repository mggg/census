Cell[CellGroupData[{

Cell["Slope over time", "Subsection",ExpressionUUID->"95ac0418-d13d-43ca-b72d-af8553340a16"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getScatterPoints", "[", "year_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"pathACS", ",", "stateCountsACS", ",", "stateCountsDec"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pathACS", "=", 
      RowBox[{"{", 
       RowBox[{"\"\<data\>\"", ",", 
        RowBox[{"ToString", "[", "year", "]"}], ",", "\"\<acs\>\"", 
        ",", "\"\<acs1\>\""}], "}"}]}], ";", "\n", 
     RowBox[{"stateCountsACS", "=", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"allStateValues", "[", 
        RowBox[{
         RowBox[{"{", "\"\<B01001A_001E\>\"", "}"}], ",", "pathACS"}], "]"}], 
       "-", "\[IndentingNewLine]", 
       RowBox[{"allStateValues", "[", 
        RowBox[{
         RowBox[{"{", "\"\<B01001H_001E\>\"", "}"}], ",", "pathACS"}], 
        "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"stateCountsDec", "=", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"allStateValues", "[", 
        RowBox[{
         RowBox[{"{", "\"\<P1_003N\>\"", "}"}], ",", "pathDec"}], "]"}], "-", 
       "\[IndentingNewLine]", 
       RowBox[{"allStateValues", "[", 
        RowBox[{
         RowBox[{"{", "\"\<P2_005N\>\"", "}"}], ",", "pathDec"}], "]"}]}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"KeyMap", "[", 
      RowBox[{"fipsStates", ",", 
       RowBox[{"Merge", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"stateCountsACS", ",", "stateCountsDec"}], "}"}], ",", 
         "Identity"}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"46aa8e1a-4e8f-4fcc-a3e9-b2307f968d20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Values", "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"getScatterPoints", "[", "2019", "]"}], ",", 
      RowBox[{"getScatterPoints", "[", "2022", "]"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Dashed", ",", 
      RowBox[{"InfiniteLine", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AspectRatio", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
