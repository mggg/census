Notebook[{

Cell[CellGroupData[{
Cell["Base", "Subsection",ExpressionUUID->"432a4680-26b7-45e7-adcf-c8c6db36c923"],

Cell["Set the Census API key", "Text",ExpressionUUID->"32f396e4-e43f-42f2-9eae-b4f41abadb6e"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}], 
   "=", "\"\<your Census API key\>\""}], "*)"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"b659ede6-e17c-4a9d-94ad-95db751b82ab"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "censusQuery", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Authentication", ":>", 
      RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"\"\<APIBase\>\"", "->", "\"\<api.census.gov\>\""}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.922479911547374*^9, 3.922479929606248*^9}, {
   3.9224800492421618`*^9, 3.922480062096148*^9}, 3.92248026029036*^9, {
   3.922538194005389*^9, 3.922538202913189*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"e93d6fb6-d419-40bb-8410-62e63d64b2c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"censusQuery", "[", 
   RowBox[{"path_", ",", "query_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Enclose", "@", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rawResponse", ",", "responseList"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rawResponse", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"URLRead", "@", 
         RowBox[{"HTTPRequest", "[", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<Scheme\>\"", "->", "\"\<HTTPS\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Domain\>\"", "->", 
             RowBox[{"OptionValue", "[", "\"\<APIBase\>\"", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Path\>\"", "->", "path"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Query\>\"", "->", 
             RowBox[{"Join", "[", "\[IndentingNewLine]", 
              RowBox[{"query", ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"\"\<key\>\"", "->", 
                 RowBox[{"OptionValue", "[", "Authentication", "]"}]}], 
                "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
           "\[IndentingNewLine]", "|>"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"responseList", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"Import", "[", 
         RowBox[{"rawResponse", ",", "\"\<RawJSON\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ToTabular", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "responseList"}], ",", "\"\<Rows\>\"", ",", 
        RowBox[{"<|", 
         RowBox[{"\"\<ColumnKeys\>\"", "->", 
          RowBox[{"First", "@", "responseList"}]}], "|>"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"ebd9afdd-6793-45d7-a72c-5ad0cf29d22c"],

Cell["Get tract-level estimates for a variable:", "Text",ExpressionUUID->"b86f0f4b-7033-4f74-8cfe-c476f90c428e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tractValues", "[", 
   RowBox[{"vars_", ",", "fipsCode_", ",", "path_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "tab", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tab", "=", 
      RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
       RowBox[{"path", ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<get\>\"", "->", 
           RowBox[{"StringRiffle", "[", 
            RowBox[{"vars", ",", "\"\<,\>\""}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<for\>\"", "->", "\"\<tract:*\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<in\>\"", "->", 
           RowBox[{"\"\<state:\>\"", "<>", "fipsCode"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<in\>\"", "->", "\"\<county:*\>\""}]}], 
         "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"tab", "=", 
      RowBox[{"ConstructColumns", "[", 
       RowBox[{"tab", ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<geoid\>\"", "->", 
           RowBox[{"Function", "[", 
            RowBox[{"#state", "<>", "#county", "<>", "#tract"}], "]"}]}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"\"\<total\>\"", "->", 
           RowBox[{"Function", "[", 
            RowBox[{"Total", "@", 
             RowBox[{"ToExpression", "@", 
              RowBox[{"Lookup", "[", 
               RowBox[{"#", ",", "vars"}], "]"}]}]}], "]"}]}]}], 
         "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"GroupBy", "[", 
      RowBox[{
       RowBox[{"FromTabular", "[", 
        RowBox[{"tab", ",", "\"\<Rows\>\""}], "]"}], ",", 
       RowBox[{
        RowBox[{"Lookup", "[", "\"\<geoid\>\"", "]"}], "->", 
        RowBox[{"Lookup", "[", "\"\<total\>\"", "]"}]}], ",", "First"}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"1c882318-0a82-463c-845b-c7cad1bc443d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allStateValues", "[", 
   RowBox[{"vars_", ",", "path_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "tab", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tab", "=", 
      RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
       RowBox[{"path", ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<get\>\"", "->", 
           RowBox[{"StringRiffle", "[", 
            RowBox[{"vars", ",", "\"\<,\>\""}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<for\>\"", "->", "\"\<state:*\>\""}]}], 
         "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"tab", "=", 
      RowBox[{"ConstructColumns", "[", 
       RowBox[{"tab", ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<geoid\>\"", "->", 
           RowBox[{"Function", "[", "#state", "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<total\>\"", "->", 
           RowBox[{"Function", "[", 
            RowBox[{"Total", "@", 
             RowBox[{"ToExpression", "@", 
              RowBox[{"Lookup", "[", 
               RowBox[{"#", ",", "vars"}], "]"}]}]}], "]"}]}]}], 
         "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"GroupBy", "[", 
      RowBox[{
       RowBox[{"FromTabular", "[", 
        RowBox[{"tab", ",", "\"\<Rows\>\""}], "]"}], ",", 
       RowBox[{
        RowBox[{"Lookup", "[", "\"\<geoid\>\"", "]"}], "->", 
        RowBox[{"Lookup", "[", "\"\<total\>\"", "]"}]}], ",", "First"}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"2fc60aa1-e0f4-4339-8a0e-4af2507d0968"]
}, Closed]],

Cell[CellGroupData[{

Cell["Comparison", "Subsection",ExpressionUUID->"f7e975c5-b082-47fe-be0b-776ed6a96257"],

Cell["\<\
We compute the number of Hispanic White alone people in each tract in Georgia \
using data from the 5 year ACS (2022 vintage) and the 2020 Decennial Census.\
\>", "Text",ExpressionUUID->"e29f9f99-cce9-494f-9270-c92b803ff5fd"],

Cell["\<\
For each, we first get the number of White alone people using the following \
variables:\
\>", "Text",ExpressionUUID->"d6a0a866-8d1a-4a5c-aec1-7a17ed35ecfa"],

Cell[TextData[{
 StyleBox["ACS",
  FontWeight->"Bold"],
 ": B01001A_001E (\"Estimate!!Total:\" from \"Sex by Age (White Alone)\")"
}], "Item",ExpressionUUID->"3d55552c-8496-49aa-b1fa-0466058cc7dc"],

Cell[TextData[{
 StyleBox["Decennial Census",
  FontWeight->"Bold"],
 ": P1_003N (\"!!Total:!!Population of one race:!!White alone\")"
}], "Item",ExpressionUUID->"37d88862-1ae5-4259-942b-a1f6ba03193e"],

Cell["\<\
We then get the number of non-Hispanic White alone people using the following \
variables:\
\>", "Text",ExpressionUUID->"8dea61a7-4ec2-46e2-b249-fee180f64a51"],

Cell[TextData[{
 StyleBox["ACS",
  FontWeight->"Bold"],
 ": B01001H_001E (\"Estimate!!Total:\" from \"Sex by Age (White Alone, Not \
Hispanic or Latino)\")"
}], "Item",ExpressionUUID->"25bc185a-39d3-43e2-9e96-6aa31e01c076"],

Cell[TextData[{
 StyleBox["Decennial Census",
  FontWeight->"Bold"],
 ": P2_005N (\"!!Total:!!Not Hispanic or Latino:!!Population of one \
race:!!White alone\")"
}], "Item",ExpressionUUID->"4ebbe3e4-59ed-4458-9abb-c7e61ef3a147"],

Cell["Compute the estimates:", "Text",ExpressionUUID->"3dcab469-6829-4752-ad72-e61cc6228ec0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pathACS", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<data\>\"", ",", "\"\<2022\>\"", ",", "\"\<acs\>\"", 
     ",", "\"\<acs5\>\""}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"f28c95be-69af-419f-8007-f3900bd1638c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pathACS", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<data\>\"", ",", "\"\<2022\>\"", ",", "\"\<acs\>\"", 
     ",", "\"\<acs5\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pathDec", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<data\>\"", ",", "\"\<2020\>\"", ",", "\"\<dec\>\"", 
     ",", "\"\<pl\>\""}], "}"}]}], ";"}]}], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"335293c8-a2a2-4a8e-ace8-5012128db88d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fipsCode", "=", 
  RowBox[{
   TemplateBox[{"\"Georgia, United States\"", 
     RowBox[{"Entity", "[", 
       RowBox[{"\"AdministrativeDivision\"", ",", 
         RowBox[{"{", 
           RowBox[{"\"Georgia\"", ",", "\"UnitedStates\""}], "}"}]}], "]"}], 
     "\"Entity[\\\"AdministrativeDivision\\\", {\\\"Georgia\\\", \
\\\"UnitedStates\\\"}]\"", "\"administrative division\""},
    "Entity"], "[", 
   TemplateBox[{"\"FIPS code\"", 
     RowBox[{"EntityProperty", "[", 
       RowBox[{"\"AdministrativeDivision\"", ",", "\"FIPSCode\""}], "]"}], 
     "\"EntityProperty[\\\"AdministrativeDivision\\\", \\\"FIPSCode\\\"]\""},
    "EntityProperty"], "]"}]}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"b33462ef-09b8-45a6-ae7e-15a6cdd5dec3"],

Cell[BoxData["\<\"13\"\>"], "Output",
 CellLabel->"Out[10]=",ExpressionUUID->"78f80c2a-a92e-4679-b5ef-cf5744afbac4"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tractCountsACS", "=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tractValues", "[", 
     RowBox[{
      RowBox[{"{", "\"\<B01001A_001E\>\"", "}"}], ",", "fipsCode", ",", 
      "pathACS"}], "]"}], "-", "\[IndentingNewLine]", 
    RowBox[{"tractValues", "[", 
     RowBox[{
      RowBox[{"{", "\"\<B01001H_001E\>\"", "}"}], ",", "fipsCode", ",", 
      "pathACS"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tractCountsDec", "=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tractValues", "[", 
     RowBox[{
      RowBox[{"{", "\"\<P1_003N\>\"", "}"}], ",", "fipsCode", ",", 
      "pathDec"}], "]"}], "-", "\[IndentingNewLine]", 
    RowBox[{"tractValues", "[", 
     RowBox[{
      RowBox[{"{", "\"\<P2_005N\>\"", "}"}], ",", "fipsCode", ",", 
      "pathDec"}], "]"}]}]}], ";"}]}], "Input",
 CellLabel->"In[39]:=",ExpressionUUID->"956f8ce3-4297-4fd5-aef3-2d18c8c62e0d"],

Cell["\<\
The results are very different from the ACS and Decennial Census:\
\>", "Text",ExpressionUUID->"c1bbf84d-e290-4f84-b832-46c711b27e86"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Values", "@", 
    RowBox[{"Merge", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"tractCountsACS", ",", "tractCountsDec"}], "}"}], ",", 
      "Identity"}], "]"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Dashed", ",", 
      RowBox[{"InfiniteLine", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AspectRatio", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1300"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1300"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<ACS N(B01001A_001E) - N(B01001H_001E)\>\"", 
      ",", "\"\<Decennial N(P1_003N) - N(P2_005N)\>\""}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->
  "In[105]:=",ExpressionUUID->"6b81222c-792c-4c84-a0be-8576e4e6e88d"],

