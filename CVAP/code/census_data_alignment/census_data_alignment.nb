  RowBox[{"stateValue", "[", 
   RowBox[{"vars_", ",", "fipsCode_", ",", "path_"}], "]"}], ":=", 
  RowBox[{"Total", "@", 
   RowBox[{"ToExpression", "@", 
    RowBox[{"Normal", "@", 
     RowBox[{
      RowBox[{"censusQuery", "[", 
       RowBox[{"path", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<get\>\"", "->", 
           RowBox[{"StringRiffle", "[", 
            RowBox[{"vars", ",", "\"\<,\>\""}], "]"}]}], ",", 
          RowBox[{"\"\<for\>\"", "->", 
           RowBox[{"\"\<state:\>\"", "<>", "fipsCode"}]}]}], "}"}]}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "vars"}], "]"}], "]"}]}]}]}]}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"4f46952d-457f-475a-aead-b0b02c035c48"],

