Cell[BoxData[{
 RowBox[{
  RowBox[{"allWhiteVarsDec", "=", 
   RowBox[{"{", "\"\<P1_003N\>\"", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nonHispanicWhiteVarsDec", "=", 
   RowBox[{"{", "\"\<P2_005N\>\"", "}"}]}], ";"}]}], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"7eb9f89e-7b0f-4046-83a9-9152065fb383"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"decTab", "=", 
  RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<data\>\"", ",", "\"\<2020\>\"", ",", "\"\<dec\>\"", 
      ",", "\"\<pl\>\""}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\"\<get\>\"", "->", 
       RowBox[{"StringRiffle", "[", 
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{"allWhiteVarsDec", ",", "nonHispanicWhiteVarsDec"}], "]"}], 
         ",", "\"\<,\>\""}], "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<for\>\"", "->", "\"\<tract:*\>\""}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<in\>\"", "->", 
       RowBox[{"\"\<state:\>\"", "<>", "fipsCode"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<in\>\"", "->", "\"\<county:*\>\""}]}], 
     "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",\

 CellLabel->"In[12]:=",ExpressionUUID->"677faaad-5308-4c6a-a071-4e37ed1e55cf"],

