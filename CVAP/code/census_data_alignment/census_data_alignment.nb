Cell["\<\
Their distributions are different too. The ACS has far more zero inflation, \
but also has a fatter tail:\
\>", "Text",ExpressionUUID->"ad80ace0-3f14-4cc1-b64f-038123c51e47"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Histogram", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"tractCountsACS", ",", "\[IndentingNewLine]", "tractCountsDec"}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", "10", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ChartLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<ACS\>\"", ",", "\"\<Decennial\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<non-hispanic white alone population\>\"", 
      ",", "\"\<# of tracts\>\""}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[42]:=",ExpressionUUID->"30aafbf5-cb85-4f85-9f4d-be6823f9013f"],

