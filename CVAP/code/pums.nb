 RowBox[{"Beep", "[", "]"}]], "Input",
 CellLabel->
  "In[448]:=",ExpressionUUID->"3c1600e5-0cc5-4e10-9bfe-2912d28ca873"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allIncome", "=", 
   RowBox[{"CastColumns", "[", "\[IndentingNewLine]", 
    RowBox[{"allIncomeRaw", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<WGTP\>\"", "->", "\"\<Integer\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<PWGTP\>\"", "->", "\"\<Integer\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<AGEP\>\"", "->", "\"\<Integer\>\""}], ",", 
       "\[IndentingNewLine]", 
