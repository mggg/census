Cell[BoxData[
 RowBox[{
  RowBox[{"georgiaPUMSCounts", "=", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{
     RowBox[{"Apply", "@", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"r", ",", "c"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Total", "@", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"georgiaPUMS", ",", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"acsCategoryPreds", "[", "r", "]"}], "[", "#", "]"}], "&&", 
              RowBox[{"#Age", ">=", "18"}], "&&", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"c", "===", "\"\<CVAP\>\""}], ",", "#Citizen", ",", 
                "True"}], "]"}]}], "&"}]}], "]"}], "[", 
          RowBox[{"[", 
