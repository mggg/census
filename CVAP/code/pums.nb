Cell[CellGroupData[{

Cell["Random socioeconomic experiments", "Subsection",ExpressionUUID->"c6cd788b-0ffe-430c-b0c3-30b2f8518f96"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"allIncomeRaw", "=", 
    RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<data\>\"", ",", "\"\<2022\>\"", ",", "\"\<acs\>\"", 
        ",", "\"\<acs5\>\"", ",", "\"\<pums\>\""}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<get\>\"", "->", 
         RowBox[{"StringRiffle", "[", 
          RowBox[{
           RowBox[{"{", 
            
            RowBox[{"\"\<WGTP\>\"", ",", "\"\<PWGTP\>\"", ",", "\"\<AGEP\>\"",
              ",", "\"\<WAGP\>\"", ",", "\"\<PINCP\>\"", ",", "\"\<GRPIP\>\"",
              ",", "\"\<HINCP\>\""}], "}"}], ",", "\"\<,\>\""}], "]"}]}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"\"\<for\>\"", "->", "\"\<state:*\>\""}]}], 
       "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "//", "EchoTiming"}]], "Input",
 CellLabel->
  "In[446]:=",ExpressionUUID->"83ea328a-2ceb-4a76-9897-fef590a0aa49"],

Cell[BoxData["558.06315`"], "EchoTiming",ExpressionUUID->"3829df34-57e9-4d92-9770-5a874e5927b7"]
}, Open  ]],

