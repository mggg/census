Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"From", " ", "ChatGPT"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gini", "[", "x_List", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xs", "=", 
         RowBox[{"Sort", "[", "x", "]"}]}], ",", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "x", "]"}]}]}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"Range", "[", "n", "]"}], ".", "xs"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"n", " ", 
          RowBox[{"Total", "[", "x", "]"}]}], ")"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "+", "1"}], ")"}], "/", "n"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gini2", "[", "wd_WeightedData", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "=", 
         RowBox[{"wd", "[", "\"\<InputData\>\"", "]"}]}], ",", 
        RowBox[{"w", "=", 
         RowBox[{"wd", "[", "\"\<Weights\>\"", "]"}]}], ",", "ord", ",", "xs",
         ",", "ws", ",", "W", ",", "Y", ",", "p", ",", "L", ",", "area"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"ord", "=", 
        RowBox[{"Ordering", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xs", "=", 
        RowBox[{"x", "[", 
         RowBox[{"[", "ord", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ws", "=", 
        RowBox[{"w", "[", 
         RowBox[{"[", "ord", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"W", "=", 
        RowBox[{"Total", "[", "ws", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Y", "=", 
        RowBox[{"Total", "[", 
         RowBox[{"ws", " ", "xs"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"W", "==", "0"}], "||", 
          RowBox[{"Y", "==", "0"}]}], ",", 
         RowBox[{"Return", "[", "Indeterminate", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Lorenz", " ", "curve", " ", "points"}], "*)"}], 
       RowBox[{"p", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Accumulate", "[", "ws", "]"}], "/", "W"}], ",", "0"}], 
         "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"cumulative", " ", "population", " ", "share"}], "*)"}], 
       RowBox[{"L", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Accumulate", "[", 
            RowBox[{"ws", " ", "xs"}], "]"}], "/", "Y"}], ",", "0"}], "]"}]}],
        ";", 
       RowBox[{"(*", 
        RowBox[{"cumulative", " ", "income", " ", "share"}], "*)"}], 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "trapezoid", " ", "area", " ", "under", " ", "Lorenz", " ", 
          "curve"}], ",", "vectorized"}], "*)"}], 
       RowBox[{"area", "=", 
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"MovingAverage", "[", 
           RowBox[{"L", ",", "2"}], "]"}], "*", 
          RowBox[{"Differences", "[", "p", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"1", "-", 
        RowBox[{"2", " ", "area"}]}]}]}], "]"}]}]}]}]], "Input",
 CellLabel->
  "In[594]:=",ExpressionUUID->"5b502328-ef94-4a65-8b3f-de9b28c4c9d8"],

