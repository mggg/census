Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "censusQuery", "]"}], "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Authentication", ":>", 
      RowBox[{"SystemCredential", "[", "\"\<USCensusAPIKey\>\"", "]"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"\"\<APIBase\>\"", "->", "\"\<api.census.gov\>\""}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.922479911547374*^9, 3.922479929606248*^9}, {
   3.9224800492421618`*^9, 3.922480062096148*^9}, 3.92248026029036*^9, {
   3.922538194005389*^9, 3.922538202913189*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"3c660866-c663-4f1b-89a6-4df97f513c0c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"censusQuery", "[", 
   RowBox[{"path_", ",", "query_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Enclose", "@", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rawResponse", ",", "responseList"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rawResponse", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"URLRead", "@", 
         RowBox[{"HTTPRequest", "[", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<Scheme\>\"", "->", "\"\<HTTPS\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Domain\>\"", "->", 
             RowBox[{"OptionValue", "[", "\"\<APIBase\>\"", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Path\>\"", "->", "path"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"\"\<Query\>\"", "->", 
             RowBox[{"Join", "[", "\[IndentingNewLine]", 
              RowBox[{"query", ",", "\[IndentingNewLine]", 
               RowBox[{"{", 
                RowBox[{"\"\<key\>\"", "->", 
                 RowBox[{"OptionValue", "[", "Authentication", "]"}]}], 
                "}"}]}], "\[IndentingNewLine]", "]"}]}]}], 
           "\[IndentingNewLine]", "|>"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"responseList", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"Import", "[", 
         RowBox[{"rawResponse", ",", "\"\<RawJSON\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ToTabular", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "responseList"}], ",", "\"\<Rows\>\"", ",", 
        RowBox[{"<|", 
         RowBox[{"\"\<ColumnKeys\>\"", "->", 
          RowBox[{"First", "@", "responseList"}]}], "|>"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->
  "In[726]:=",ExpressionUUID->"0190ff1a-7037-4cfa-b92b-42f006428df0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["PUMS", "Subsection",ExpressionUUID->"1c4c846c-ed09-48c1-a2b7-61992c892e79"],

Cell["\<\
https://www.census.gov/data/developers/data-sets/census-microdata-api.ACS_5-\
Year_PUMS.html\
\>", "Text",ExpressionUUID->"64bd5cb8-26a7-465d-bf76-fe70a017ef19"],

Cell["\<\
Variable interpretations: \
https://api.census.gov/data/2022/acs/acs5/pums/variables/CIT.json\
\>", "Text",ExpressionUUID->"52bba482-1015-44d4-a47a-a6e359535b63"],

Cell["\<\
Information on handling weights: \
https://www.census.gov/content/dam/Census/library/publications/2020/acs/acs_\
pums_handbook_2020_ch04.pdf\
\>", "Text",ExpressionUUID->"accdc409-5127-4911-afa6-a127cf704aa2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"georgiaPUMSRaw", "=", 
    RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<data\>\"", ",", "\"\<2022\>\"", ",", "\"\<acs\>\"", 
        ",", "\"\<acs5\>\"", ",", "\"\<pums\>\""}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<get\>\"", "->", 
         RowBox[{"StringRiffle", "[", 
          RowBox[{
           RowBox[{"{", 
            
            RowBox[{"\"\<PWGTP\>\"", ",", "\"\<CIT\>\"", ",", "\"\<AGEP\>\"", 
             ",", "\"\<HISP\>\"", ",", "\"\<RACWHT\>\"", ",", "\"\<RACBLK\>\"",
              ",", "\"\<RACASN\>\"", ",", "\"\<RACAIAN\>\"", 
             ",", "\"\<RACNH\>\"", ",", "\"\<RACPI\>\"", ",", "\"\<RACSOR\>\"",
              ",", "\"\<RACNUM\>\""}], "}"}], ",", "\"\<,\>\""}], "]"}]}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"\"\<for\>\"", "->", 
         RowBox[{"\"\<state:\>\"", "<>", 
          RowBox[{
           TemplateBox[{"\"Georgia, United States\"", 
             RowBox[{"Entity", "[", 
               RowBox[{"\"AdministrativeDivision\"", ",", 
                 RowBox[{"{", 
                   RowBox[{"\"Georgia\"", ",", "\"UnitedStates\""}], "}"}]}], 
               "]"}], "\"Entity[\\\"AdministrativeDivision\\\", \
{\\\"Georgia\\\", \\\"UnitedStates\\\"}]\"", "\"administrative division\""},
            "Entity"], "[", 
           TemplateBox[{"\"FIPS code\"", 
             RowBox[{"EntityProperty", "[", 
               RowBox[{"\"AdministrativeDivision\"", ",", "\"FIPSCode\""}], 
               "]"}], "\"EntityProperty[\\\"AdministrativeDivision\\\", \
\\\"FIPSCode\\\"]\""},
            "EntityProperty"], "]"}]}]}], ","}], "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"\"\<for\>\"", 
         "->", "\"\<public use microdata area:00500\>\""}], "*)"}], 
       "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "//", "EchoTiming"}]], "Input",
 CellLabel->
  "In[473]:=",ExpressionUUID->"3768f7a0-3a1a-4684-8edc-0c1ce69953df"],

Cell[BoxData["35.970532`"], "EchoTiming",ExpressionUUID->"26b6570e-8a8d-4cbf-a3c8-9135dc75fc3e"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"georgiaPUMS", "=", 
   RowBox[{"ConstructColumns", "[", 
    RowBox[{"georgiaPUMSRaw", ",", "\[IndentingNewLine]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<PersonWeight\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"Cast", "[", 
          RowBox[{"#PWGTP", ",", "\"\<UnsignedInteger16\>\""}], "]"}], 
         "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"\"\<Age\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"Cast", "[", 
          RowBox[{"#AGEP", ",", "\"\<UnsignedInteger8\>\""}], "]"}], "]"}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"\"\<Citizen\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#CIT", "=!=", "\"\<5\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<HispanicOrLatino\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#HISP", "=!=", "\"\<01\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<White\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#RACWHT", "===", "\"\<1\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<BlackOrAfricanAmerican\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#RACBLK", "===", "\"\<1\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<Asian\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#RACASN", "===", "\"\<1\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<AmericanIndianAndAlaskaNative\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#RACAIAN", "===", "\"\<1\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<NativeHawaiianAndOtherPacificIslander\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"#RACNH", "===", "\"\<1\>\""}], "||", 
          RowBox[{"#RACPI", "===", "\"\<1\>\""}]}], "]"}]}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "PUMS", " ", "splits", " ", "only", " ", "this", " ", "category", " ",
          "into", " ", "two", " ", "variables", " ", "for", " ", "some", " ", 
         "reason"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"\"\<SomeOtherRace\>\"", "->", 
        RowBox[{"Function", "[", 
         RowBox[{"#RACSOR", "===", "\"\<1\>\""}], "]"}]}]}], 
      "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[634]:=",ExpressionUUID->"c2b717c5-ec03-42b9-ab0b-5f8f69d3c9e7"],

