Cell[CellGroupData[{

Cell["Income distribution over time", "Subsection",ExpressionUUID->"704b203e-8351-47a0-a1bf-59185829a70f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"householdIncomeWeightedData", "[", "year_", "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Enclose", "@", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "t", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"t", "=", 
       RowBox[{"Confirm", "@", 
        RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           
           RowBox[{"\"\<data\>\"", ",", "year", ",", "\"\<acs\>\"", 
            ",", "\"\<acs1\>\"", ",", "\"\<pums\>\""}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<get\>\"", "->", 
             RowBox[{"StringRiffle", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"\"\<WGTP\>\"", ",", "\"\<HINCP\>\""}], "}"}], 
               ",", "\"\<,\>\""}], "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<for\>\"", "->", "\"\<state:*\>\""}]}], 
           "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"t", "=", 
       RowBox[{"CastColumns", "[", 
        RowBox[{"t", ",", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\"\<WGTP\>\"", ",", "\"\<HINCP\>\""}], "}"}], 
          "->", "\"\<Integer\>\""}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"t", "=", 
       RowBox[{"Discard", "[", 
        RowBox[{"t", ",", 
         RowBox[{
          RowBox[{"#HINCP", "===", 
           RowBox[{"-", "60000"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"WeightedData", "[", 
       RowBox[{
        RowBox[{"Normal", "@", 
         RowBox[{"t", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "\"\<HINCP\>\""}], "]"}], "]"}]}], ",", 
        RowBox[{"Normal", "@", 
         RowBox[{"t", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "\"\<WGTP\>\""}], "]"}], "]"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->
  "In[562]:=",ExpressionUUID->"9f0dd641-ebb6-4d11-8591-2f47f1281d63"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"yearIncomeDistributions", "=", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Echo", "@", 
         RowBox[{"DateObject", "[", 
          RowBox[{"{", "#", "}"}], "]"}]}], "->", 
        RowBox[{"householdIncomeWeightedData", "[", 
         RowBox[{"IntegerString", "[", "#", "]"}], "]"}]}], "&"}], "/@", 
      RowBox[{"Complement", "[", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{"2006", ",", "2024"}], "]"}], ",", 
        RowBox[{"{", "2020", "}"}]}], "]"}]}], "|>"}]}], ";"}], "//", 
  "EchoTiming"}]], "Input",
 CellLabel->
  "In[563]:=",ExpressionUUID->"a64d8a3c-add6-46b6-9030-159a2e9fcfd6"],

