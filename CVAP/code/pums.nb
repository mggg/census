Cell[BoxData[
 RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\"\<data\>\"", ",", "\"\<2023\>\"", ",", "\"\<acs\>\"", 
     ",", "\"\<acs5\>\"", ",", "\"\<pums\>\""}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<tabulate\>\"", "\[Rule]", "\"\<weight(PWGTP)\>\""}], ",", 
     RowBox[{"\"\<col SEX\>\"", "\[Rule]", "\"\<\>\""}], ",", 
     RowBox[{"\"\<row MAR\>\"", "\[Rule]", "\"\<\>\""}], ",", 
     RowBox[{"\"\<for\>\"", 
      "\[Rule]", "\"\<public use microdata area:00500\>\""}], ",", 
     RowBox[{"\"\<in\>\"", "\[Rule]", "\"\<state:12\>\""}], ",", 
     RowBox[{"\"\<SCHL\>\"", "\[Rule]", "\"\<24\>\""}]}], "}"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
