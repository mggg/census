         RowBox[{
          RowBox[{"#HINCP", "===", 
           RowBox[{"-", "60000"}]}], "&"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"Floor", "[", 
         RowBox[{"#AGEP", ",", "25"}], "]"}], "&"}]}], "]"}]}]}], ",", 
