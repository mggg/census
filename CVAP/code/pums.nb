Cell[CellGroupData[{

Cell["Comparing to ACS", "Subsection",ExpressionUUID->"01fa9137-61b5-4b90-9570-b12fbda3d2d7"],

Cell[CellGroupData[{

Cell["Init", "Subsubsection",ExpressionUUID->"b598b19e-a504-4001-bbac-0fe0b4dd5ded"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"getACSStateRaw", "[", 
   RowBox[{"state_", ",", "r_", ",", 
    RowBox[{"year_", ":", "$defaultACSVintage"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rawResponse", ",", "rawAcsData", ",", "vapVars", ",", "cvapVars"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"vapVars", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"getVAPVarsACS", "[", "r", "]"}], ",", 
        RowBox[{"getVAPErrorVarsACS", "[", "r", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cvapVars", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"getCVAPVarsACS", "[", "r", "]"}], ",", 
        RowBox[{"getCVAPErrorVarsACS", "[", "r", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rawAcsData", "=", 
      RowBox[{"censusQuery", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<data\>\"", ",", "year", ",", "\"\<acs\>\"", 
          ",", "\"\<acs5\>\""}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<get\>\"", "->", 
           RowBox[{"StringRiffle", "[", 
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{"vapVars", ",", "cvapVars"}], "]"}], ",", "\"\<,\>\""}],
             "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<for\>\"", "->", 
           RowBox[{"\"\<state:\>\"", "<>", 
            RowBox[{"Replace", "[", 
             RowBox[{"state", ",", 
              RowBox[{"_Entity", ":>", 
               RowBox[{"state", "[", "\"\<FIPSCode\>\"", "]"}]}]}], 
             "]"}]}]}]}], "\[IndentingNewLine]", "}"}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Map", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"c", "|->", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"c", ",", "\"\<VAP\>\""}], "}"}], "->", 
             RowBox[{"Total", "@", 
              RowBox[{"ToExpression", "@", 
               RowBox[{"Lookup", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"getVAPVarsACS", "[", "c", "]"}]}], "]"}]}]}]}], ",",
             "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"c", ",", "\"\<CVAP\>\""}], "}"}], "->", 
             RowBox[{"Total", "@", 
              RowBox[{"ToExpression", "@", 
               RowBox[{"Lookup", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"getCVAPVarsACS", "[", "c", "]"}]}], "]"}]}]}]}]}], 
           "\[IndentingNewLine]", "|>"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Flatten", "[", 
          RowBox[{"{", "r", "}"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
       "&"}], "@", 
      RowBox[{"First", "@", 
       RowBox[{"Normal", "@", "rawAcsData"}]}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getACSState", "[", 
   RowBox[{"state_", ",", "r_", ",", 
    RowBox[{"year_", ":", "$defaultACSVintage"}]}], "]"}], ":=", 
  RowBox[{"Merge", "[", 
   RowBox[{
    RowBox[{"BlockMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"getACSStateRaw", "[", 
        RowBox[{"state", ",", "#", ",", "year"}], "]"}], "&"}], ",", "r", ",", 
      RowBox[{"UpTo", "[", "4", "]"}]}], "]"}], ",", "Last"}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[740]:=",ExpressionUUID->"8301aa65-eac4-41e4-aae2-244d1b31992a"]
}, Open  ]],

