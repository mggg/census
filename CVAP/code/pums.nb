Cell["Sanity check with the RACNUM variable:", "Text",ExpressionUUID->"02b21470-9490-490f-8ea8-7d6c069b39e1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ConstructColumns", "[", 
    RowBox[{"georgiaPUMS", ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<raceNum\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{"Total", "@", 
        RowBox[{"Boole", "@", 
         RowBox[{"Lookup", "[", 
          RowBox[{"#", ",", 
           RowBox[{"{", 
            
            RowBox[{"\"\<White\>\"", ",", "\"\<BlackOrAfricanAmerican\>\"", 
             ",", "\"\<Asian\>\"", 
             ",", "\"\<AmericanIndianAndAlaskaNative\>\"", 
             ",", "\"\<NativeHawaiianAndOtherPacificIslander\>\"", 
             ",", "\"\<SomeOtherRace\>\""}], "}"}]}], "]"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "\"\<raceNum\>\""}], "]"}], "]"}], "===", 
  RowBox[{
   RowBox[{"CastColumns", "[", 
    RowBox[{"georgiaPUMSRaw", ",", 
     RowBox[{"\"\<RACNUM\>\"", "->", "\"\<Integer64\>\""}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "\"\<RACNUM\>\""}], "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[636]:=",ExpressionUUID->"4adee07e-f28c-427e-a5da-a6dd278993fa"],

Cell[BoxData["True"], "Output",
 CellLabel->
  "Out[636]=",ExpressionUUID->"03ad0d5e-f3d8-4480-9a82-7dbfe42299c6"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"acsCategoryPreds", "=", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<WhiteAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{"#White", "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", 
        RowBox[{"!", "#Asian"}], "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<BlackOrAfricanAmericanAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#White"}], "&&", "#BlackOrAfricanAmerican", "&&", 
        RowBox[{"!", "#Asian"}], "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<AsianAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#White"}], "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", "#Asian", "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<AmericanIndianAndAlaskaNativeAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#White"}], "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", 
        RowBox[{"!", "#Asian"}], "&&", "#AmericanIndianAndAlaskaNative", "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<NativeHawaiianAndOtherPacificIslanderAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#White"}], "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", 
        RowBox[{"!", "#Asian"}], "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        "#NativeHawaiianAndOtherPacificIslander", "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<SomeOtherRaceAlone\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#White"}], "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", 
        RowBox[{"!", "#Asian"}], "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        "#SomeOtherRace"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<TwoOrMore\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"Total", "@", 
         RowBox[{"Boole", "@", 
          RowBox[{"{", 
           RowBox[{
           "#White", ",", "#BlackOrAfricanAmerican", ",", "#Asian", ",", 
            "#AmericanIndianAndAlaskaNative", ",", 
            "#NativeHawaiianAndOtherPacificIslander", ",", "#SomeOtherRace"}],
            "}"}]}]}], ">=", "2"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<HispanicOrLatino\>\"", "->", 
      RowBox[{"Function", "[", "#HispanicOrLatino", "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<WhiteAloneNotHispanicOrLatino\>\"", "->", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"!", "#HispanicOrLatino"}], "&&", "#White", "&&", 
        RowBox[{"!", "#BlackOrAfricanAmerican"}], "&&", 
        RowBox[{"!", "#Asian"}], "&&", 
        RowBox[{"!", "#AmericanIndianAndAlaskaNative"}], "&&", 
        RowBox[{"!", "#NativeHawaiianAndOtherPacificIslander"}], "&&", 
        RowBox[{"!", "#SomeOtherRace"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<Overall\>\"", "->", 
      RowBox[{"Function", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
    "|>"}]}], ";"}]], "Input",
 CellLabel->
